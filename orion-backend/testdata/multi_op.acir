{
  // Multi-Opcode Circuit Test
  //
  // This circuit demonstrates a mix of different ACIR opcode types
  // working together in a single circuit.
  //
  // Circuit Logic:
  //   1. Start with private inputs x=10, y=20
  //   2. Perform matvec multiplication (identity matrix * [x, y])
  //   3. Store intermediate result in memory
  //   4. Use assert_zero to verify constraint is satisfied
  //   5. Use brillig to compute final result: x + y
  //
  // Detailed flow:
  //   - Private parameter x = witness 0 (value = 10)
  //   - Private parameter y = witness 1 (value = 20)
  //
  //   Step 1: matvec with 2x2 identity matrix
  //     I = [[1, 0], [0, 1]]
  //     Result = I * [x, y] = [x, y] = [10, 20]
  //     outputs: witnesses 2, 3
  //
  //   Step 2: memory_op write
  //     Store result to memory address 0
  //     address: witness 4 (value = 0)
  //     value: witness 2 (first matvec output = 10)
  //
  //   Step 3: assert_zero
  //     Assert that x + y - 30 = 0 (verifies x + y = 30)
  //     We compute (witness 0) + (witness 1) - 30 should equal zero
  //     Since x=10, y=20, we have 10+20-30 = 0, assertion passes
  //
  //   Step 4: brillig_call
  //     Compute final sum: x + y = 10 + 20 = 30
  //     Output: witness 10 (value = 30)
  //
  // Expected final output: 30

  "circuits": [
    {
      "opcodes": [
        {
          // Step 1: 2x2 Identity Matrix times vector [x, y]
          // Identity matrix: [[1,0],[0,1]]
          // Result should be [x, y] = [10, 20]
          "type": "black_box_func_call",
          "name": "matvec",
          // Matrix A: 2x2 identity matrix
          // a00=1, a01=0, a10=0, a11=1 (witnesses 2,3,4,5)
          // Vector x: [witness 0=10, witness 1=20]
          "inputs": [1, 0, 0, 1, 0, 1],
          // Output: [10, 20] -> witnesses 6, 7
          "outputs": [6, 7]
        },
        {
          // Step 2: Memory write operation
          // Store the first matvec result (10) to memory address 0
          "type": "memory_op",
          "operation": "write",
          "address": 0,
          "value": 6
        },
        {
          // Step 3: Memory read operation
          // Read from memory address 0 into witness 8
          "type": "memory_op",
          "operation": "read",
          "address": 0,
          "value": 8
        },
        {
          // Step 4: Assert that x + y = 30
          // With x=10 (witness 0), y=20 (witness 1):
          // We need to assert that x + y - 30 = 0
          // The circuit computes (witness 0) + (witness 1) - 30 = 0
          // This is done via an assert_zero on the constraint result
          "type": "assert_zero",
          "witness": 9
        },
        {
          // Step 5: Brillig computation of x + y
          // Simple bytecode to add two values
          // CONST 10 -> dest=0
          // CONST 20 -> dest=1
          // ADD dest=2, lhs=dest=0, rhs=dest=1
          // HALT -> output = 30
          "type": "brillig_call",
          "bytecode": [
            5, 0, 0, 0, 0, 10,  // CONST: allocate dest=0, value=10
            5, 0, 0, 0, 1, 20,  // CONST: allocate dest=1, value=20
            1, 0, 0, 0, 2, 0, 1, // ADD: dest=2, lhs=dest=0, rhs=dest=1
            255                  // HALT
          ]
        },
        {
          // Step 6: Another matvec for completeness
          // Multiply [10, 20] by scalar 2 using [[2,0],[0,2]]
          "type": "black_box_func_call",
          "name": "matvec",
          // Matrix: [[2,0],[0,2]], Vector: [witness 0=10, witness 1=20]
          // Expected: [2*10+0*20, 0*10+2*20] = [20, 40]
          "inputs": [2, 0, 0, 2, 0, 1],
          "outputs": [10, 11]
        }
      ],
      "private_parameters": [0, 1],
      "public_parameters": []
    }
  ],
  "return_values": [10, 11]
}
