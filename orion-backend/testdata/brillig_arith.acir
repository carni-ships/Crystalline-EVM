{
  // Brillig Bytecode for Basic Arithmetic Test
  //
  // Brillig is Noir's embedded assembly runtime for low-level operations.
  // This test exercises basic arithmetic operations via Brillig bytecode.
  //
  // Brillig Bytecode Structure:
  //   [opcode, operand1, operand2, ...]
  //
  // Operations tested:
  //   1. ADD:     0x01 - Add two field elements
  //   2. SUB:     0x02 - Subtract field elements
  //   3. MUL:     0x03 - Multiply field elements
  //   4. DIV:     0x04 - Divide field elements
  //   5. CONST:   0x05 - Load a constant
  //   6. LOAD:    0x06 - Load from memory
  //   7. STORE:   0x07 - Store to memory
  //   8. JUMP:    0x08 - Unconditional jump
  //   9. EQ:      0x09 - Equality check
  //   10. HALT:   0xFF - End execution
  //
  // Test Program:
  //   CONST 5      -> Load constant 5
  //   STORE 0      -> Store to memory position 0
  //   CONST 3      -> Load constant 3
  //   STORE 1      -> Store to memory position 1
  //   LOAD 0       -> Load from position 0 (value = 5)
  //   LOAD 1       -> Load from position 1 (value = 3)
  //   ADD          -> Stack: [8]
  //   HALT         -> End execution, output = 8
  //
  // Expected result: 5 + 3 = 8

  "circuits": [
    {
      "opcodes": [
        {
          "type": "brillig_call",
          // Brillig bytecode sequence for basic addition
          // Bytecode breakdown:
          // [0x05, 0, 0, 0, 0, 5]   -> CONST at dest=0, value=5 (allocate and set to 5)
          // [0x07, 0, 0, 0, 0, 0]   -> STORE at addr=0, value comes from const result
          // [0x05, 0, 0, 0, 1, 3]   -> CONST at dest=1, value=3
          // [0x07, 0, 0, 0, 1, 1]   -> STORE at addr=1, value comes from const result
          // [0x06, 0, 0, 0, 0, 0]   -> LOAD dest=0 from addr=0
          // [0x06, 0, 0, 0, 2, 1]   -> LOAD dest=2 from addr=1
          // [0x01, 0, 0, 0, 0, 2, 3] -> ADD dest=3, lhs=0 (5), rhs=2 (3)
          // [0xFF]                   -> HALT
          "bytecode": [
            5, 0, 0, 0, 0, 5,
            7, 0, 0, 0, 0, 0,
            5, 0, 0, 0, 1, 3,
            7, 0, 0, 0, 1, 1,
            6, 0, 0, 0, 0, 0,
            6, 0, 0, 0, 2, 1,
            1, 0, 0, 0, 0, 2, 3,
            255
          ]
        }
      ],
      "private_parameters": [],
      "public_parameters": []
    }
  ],
  "return_values": [3]
}
