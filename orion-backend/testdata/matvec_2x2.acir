{
  // 2x2 Matrix-Vector Multiplication Test
  //
  // This circuit performs: y = A * x
  // where A is a 2x2 matrix and x is a 2-element vector
  //
  // Matrix A (witnesses 0-3):
  //   [1, 2]
  //   [3, 4]
  //
  // Vector x (witnesses 4-5):
  //   [5]
  //   [6]
  //
  // Expected output y (witnesses 6-7):
  //   y[0] = 1*5 + 2*6 = 5 + 12 = 17
  //   y[1] = 3*5 + 4*6 = 15 + 24 = 39
  //
  // Public parameters: [] - all inputs are private
  // Private parameters: [0, 1, 2, 3, 4, 5] - matrix A and vector x
  // Return values: [6, 7] - output vector y

  "circuits": [
    {
      "opcodes": [
        {
          "type": "black_box_func_call",
          "name": "matvec",
          // Input witnesses: [a00, a01, a10, a11, x0, x1]
          // witnesses 0-3 are matrix A, witnesses 4-5 are vector x
          "inputs": [0, 1, 2, 3, 4, 5],
          // Output witnesses: [y0, y1]
          // y0 = a00*x0 + a01*x1 = 1*5 + 2*6 = 17
          // y1 = a10*x0 + a11*x1 = 3*5 + 4*6 = 39
          "outputs": [6, 7]
        }
      ],
      "private_parameters": [0, 1, 2, 3, 4, 5],
      "public_parameters": []
    }
  ],
  "return_values": [6, 7]
}
